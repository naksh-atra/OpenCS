---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { categories } from '../../data/categories';

const allTopics = await getCollection('topics');
const url = Astro.url;
const categoryFilter = url.searchParams.get('category');

const filteredTopics = categoryFilter
  ? allTopics.filter(t => t.data.category === categoryFilter)
  : allTopics;

const sortedTopics = filteredTopics.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Topics" description="Browse all computer science topics with interactive visualizations">
  <Header />
  <main>
    <section class="topics-header">
      <div class="container">
        <h1>Topics</h1>
        <p>Explore interactive visualizations of core BTech CSE concepts</p>
      </div>
    </section>

    <section class="topics-filters">
      <div class="container">
        <div class="filter-tabs">
          <a href="/OpenCS/topics" class:list={['filter-tab', { active: !categoryFilter }]}>
            All Topics
          </a>
          {categories.map(cat => (
            <a
              href={`/OpenCS/topics?category=${cat.slug}`}
              class:list={['filter-tab', { active: categoryFilter === cat.slug }]}
            >
              {cat.label}
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="topics-list">
      <div class="container">
        {sortedTopics.length === 0 ? (
          <div class="empty-state">
            <h3>No topics yet</h3>
            <p>This category is still being built. Check back soon!</p>
            <a href="/OpenCS/contribute">Want to help build it?</a>
          </div>
        ) : (
          <div class="topics-grid">
            {sortedTopics.map(topic => (
              <a href={`/OpenCS/topics/${topic.id.replace(/\.mdx?$/, '')}`} class="topic-card">
                <div class="topic-card-header">
                  <span class="topic-engine">{topic.data.engine}</span>
                  <span class="topic-status status-{topic.data.status}">{topic.data.status}</span>
                </div>
                <h3>{topic.data.title}</h3>
                <p>{topic.data.description}</p>
                <div class="topic-card-footer">
                  <span class="topic-difficulty">{topic.data.difficulty}</span>
                  <span class="topic-time">{topic.data.estimatedTime}</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .topics-header {
    padding: var(--space-12) 0 var(--space-6);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .topics-header h1 {
    margin-bottom: var(--space-2);
  }

  .topics-header p {
    color: var(--color-text-muted);
  }

  .topics-filters {
    padding: var(--space-4) 0;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: var(--header-height);
    z-index: 50;
  }

  .filter-tabs {
    display: flex;
    gap: var(--space-2);
    overflow-x: auto;
    padding-bottom: var(--space-1);
  }

  .filter-tab {
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.15s;
  }

  .filter-tab:hover {
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
  }

  .filter-tab.active {
    background: var(--color-primary);
    color: white;
  }

  .topics-list {
    padding: var(--space-8) 0 var(--space-16);
  }

  .topics-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .topic-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all 0.15s;
  }

  .topic-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md);
    text-decoration: none;
  }

  .topic-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }

  .topic-engine {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    background: var(--color-bg);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .topic-status {
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .status-planned {
    background: #fef3c7;
    color: #92400e;
  }

  .status-in-progress {
    background: #dbeafe;
    color: #1e40af;
  }

  .status-published {
    background: #d1fae5;
    color: #065f46;
  }

  .topic-card h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  .topic-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    flex: 1;
    margin-bottom: var(--space-4);
  }

  .topic-card-footer {
    display: flex;
    gap: var(--space-4);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .empty-state {
    text-align: center;
    padding: var(--space-12);
    background: var(--color-surface);
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-state h3 {
    margin-bottom: var(--space-2);
  }

  .empty-state p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  @media (max-width: 1024px) {
    .topics-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .topics-grid {
      grid-template-columns: 1fr;
    }
  }
</style>