---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="footer-logo">OpenCS</span>
        <p class="footer-tagline">Visual learning for BTech CSE</p>
      </div>

      <nav class="footer-nav">
        <div class="footer-section">
          <h4>Project</h4>
          <a href="/OpenCS/about">About</a>
          <a href="/OpenCS/roadmap">Roadmap</a>
          <a href="/OpenCS/contribute">Contribute</a>
        </div>
        <div class="footer-section">
          <h4>Topics</h4>
          <a href="/OpenCS/topics">All Topics</a>
          <a href="/OpenCS/topics?category=algorithms">Algorithms</a>
          <a href="/OpenCS/topics?category=data-structures">Data Structures</a>
          <a href="/OpenCS/topics?category=theory">Theory</a>
          <a href="/OpenCS/topics?category=systems">Systems</a>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} OpenCS. MIT License.</p>
      <p>Built for BTech CSE students in India</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    padding: var(--space-8) 0 var(--space-6);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-8);
    margin-bottom: var(--space-6);
  }

  .footer-brand {
    max-width: 20rem;
  }

  .footer-logo {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .footer-tagline {
    margin-top: var(--space-2);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .footer-nav {
    display: flex;
    gap: var(--space-12);
  }

  .footer-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-section h4 {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .footer-section a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-section a:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .footer-nav {
      flex-direction: column;
      gap: var(--space-6);
    }

    .footer-bottom {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>