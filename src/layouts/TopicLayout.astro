---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  difficulty?: string;
  estimatedTime?: string;
  category?: string;
  prerequisites?: string[];
  learningObjectives?: string[];
}

const { title, description, difficulty, estimatedTime, category, prerequisites = [], learningObjectives = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="topic-main">
    <article class="topic-article container">
      <header class="topic-header">
        <div class="topic-meta">
          {category && <span class="topic-category">{category}</span>}
          {difficulty && <span class="topic-difficulty">{difficulty}</span>}
          {estimatedTime && <span class="topic-time">{estimatedTime}</span>}
        </div>
        <h1>{title}</h1>
        {description && <p class="topic-description">{description}</p>}
      </header>

      <div class="topic-content">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .topic-main {
    padding: var(--space-8) 0;
  }

  .topic-article {
    max-width: 48rem;
  }

  .topic-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .topic-meta {
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-3);
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .topic-meta span {
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .topic-header h1 {
    margin-bottom: var(--space-3);
  }

  .topic-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .topic-content {
    line-height: 1.8;
  }

  .topic-content :global(h2) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .topic-content :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .topic-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .topic-content :global(ul),
  .topic-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .topic-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .topic-content :global(pre) {
    margin-bottom: var(--space-4);
  }

  .topic-content :global(.visualizer) {
    margin: var(--space-6) 0;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  @media (max-width: 640px) {
    .topic-meta {
      flex-wrap: wrap;
    }
  }
</style>