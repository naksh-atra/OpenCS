---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  difficulty?: string;
  estimatedTime?: string;
  category?: string;
  engine?: string;
  status?: string;
  prerequisites?: string[];
  learningObjectives?: string[];
}

const { title, description, difficulty, estimatedTime, category, engine, status, prerequisites = [], learningObjectives = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <main class="topic-main">
    <article class="topic-article container">
      <header class="topic-header">
        <div class="topic-meta">
          {category && <span class="topic-category">{category}</span>}
          {engine && <span class="topic-engine">{engine}</span>}
          {difficulty && <span class={`topic-difficulty ${difficulty}`}>{difficulty}</span>}
          {status && <span class={`topic-status status-${status}`}>{status}</span>}
          {estimatedTime && <span class="topic-time">{estimatedTime}</span>}
        </div>
        <h1>{title}</h1>
        {description && <p class="topic-description">{description}</p>}

        {learningObjectives.length > 0 && (
          <div class="topic-objectives">
            <h4>Learning Objectives</h4>
            <ul>
              {learningObjectives.map(obj => <li>{obj}</li>)}
            </ul>
          </div>
        )}
      </header>

      <div class="topic-content">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .topic-main {
    padding: var(--space-8) 0;
  }

  .topic-article {
    max-width: 48rem;
  }

  .topic-header {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .topic-meta {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    flex-wrap: wrap;
  }

  .topic-meta span {
    padding: var(--space-1) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-transform: capitalize;
  }

  .topic-category {
    font-weight: 500;
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .topic-engine {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .topic-difficulty.beginner {
    background: #d1fae5;
    color: #065f46;
    border-color: #d1fae5;
  }

  .topic-difficulty.intermediate {
    background: #dbeafe;
    color: #1e40af;
    border-color: #dbeafe;
  }

  .topic-difficulty.advanced {
    background: #fce7f3;
    color: #9d174d;
    border-color: #fce7f3;
  }

  .status-planned {
    background: #fef3c7;
    color: #92400e;
  }

  .status-in-progress {
    background: #dbeafe;
    color: #1e40af;
  }

  .status-published {
    background: #d1fae5;
    color: #065f46;
  }

  .topic-header h1 {
    margin-bottom: var(--space-3);
  }

  .topic-description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-4);
  }

  .topic-objectives {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-6);
  }

  .topic-objectives h4 {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .topic-objectives ul {
    margin: 0;
    padding-left: var(--space-4);
  }

  .topic-objectives li {
    margin-bottom: var(--space-1);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .topic-content {
    line-height: 1.8;
  }

  .topic-content :global(h2) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .topic-content :global(h3) {
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .topic-content :global(p) {
    margin-bottom: var(--space-4);
  }

  .topic-content :global(ul),
  .topic-content :global(ol) {
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .topic-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .topic-content :global(pre) {
    margin-bottom: var(--space-4);
  }

  .topic-content :global(.visualizer) {
    margin: var(--space-6) 0;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .topic-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-4);
    font-size: 0.875rem;
  }

  .topic-content :global(th),
  .topic-content :global(td) {
    padding: var(--space-2) var(--space-4);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .topic-content :global(th) {
    background: var(--color-bg);
    font-weight: 600;
  }

  :global(.topic-nav) {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  :global(.topic-nav-inner) {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
  }

  :global(.topic-nav-link) {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.15s;
    max-width: 280px;
    flex: 1;
  }

  :global(.topic-nav-link:hover) {
    border-color: var(--color-primary);
    text-decoration: none;
  }

  :global(.topic-nav-next) {
    text-align: right;
    margin-left: auto;
  }

  :global(.topic-nav-direction) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  :global(.topic-nav-title) {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text);
  }

  @media (max-width: 640px) {
    .topic-meta {
      flex-wrap: wrap;
    }

    :global(.topic-nav-inner) {
      flex-direction: column;
    }

    :global(.topic-nav-link) {
      max-width: 100%;
    }
  }
</style>